# ===== 必填：LLM / Embedding 凭证 =====
# 智谱 GLM API Key (https://open.bigmodel.cn/)
ZHIPU_API_KEY=

# ===== 可选：OpenAI 兼容服务配置 =====
# 留空则使用默认 GLM 端点。可改为 DeepSeek / OpenAI / 代理等 OpenAI 兼容服务。
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# ===== 可选：模型名 =====
LLM_MODEL=glm-4-plus

# ===== Embedding 后端（统一走 OpenAI 兼容接口，可与 LLM 不同来源）=====
# GLM / DeepSeek / OpenAI / 自建 Ollama 的 /v1/embeddings 都接同一套代码，无需特殊适配。
EMBED_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
EMBED_MODEL=embedding-3
# API Key 留空则回退到上面的 ZHIPU_API_KEY（Ollama 等 keyless 服务填任意非空值即可）。
EMBED_API_KEY=

# --- 示例：LLM 用 GLM，Embedding 用自建 Ollama（OpenAI 兼容层 /v1）---
# EMBED_BASE_URL=http://43.138.247.132:11434/v1
# EMBED_MODEL=nomic-embed-text
# EMBED_API_KEY=ollama   # 任意非空值即可，Ollama 不校验

# ===== 可选：研究流程参数（均有内置默认值）=====
# 生成的子查询数量（决定研究广度，建议 3-5）
MAX_ITERATIONS=3
# 每个子查询返回的搜索结果条数（DuckDuckGo）
MAX_RESULTS=5
# 每个子查询实际抓取的网页数（从搜索结果中取前 N 个）
MAX_SCRAPE=3
# embedding 相似度过滤阈值（0~1，越高越严格；低于阈值的段落被丢弃）
SIMILARITY_THRESHOLD=0.42
# 当单次抓取总字符数小于该值时跳过压缩（快路径）
COMPRESSION_THRESHOLD=8000
# 最终报告目标字数
TOTAL_WORDS=1200
# 报告语言（zh / english）
LANGUAGE=zh
# 生成温度
TEMPERATURE=0.35
# 子查询并发数
CONCURRENCY=3
