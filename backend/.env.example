# ===== 必填：LLM 凭证 =====
# 智谱 GLM API Key (https://open.bigmodel.cn/)  —— 请填入你自己的密钥
ZHIPU_API_KEY=

# ===== 代理（墙内访问 DuckDuckGo / Jina Reader 必需）=====
# DuckDuckGo 与 Jina Reader 在墙内无法直连，必须配代理。
# Go 的 http 库默认尊重 HTTP_PROXY / HTTPS_PROXY 环境变量。
# 填你的本地代理端口（v2rayN 默认 10808，Clash 默认 7890）。
# 注意：TUN 模式通常不会接管 Go 程序，必须显式设这两个变量。
HTTP_PROXY=http://127.0.0.1:10808
HTTPS_PROXY=http://127.0.0.1:10808

# ===== LLM（OpenAI 兼容）=====
# 留空则使用默认 GLM 端点。可改为 DeepSeek / OpenAI / 代理等 OpenAI 兼容服务。
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL 是兜底默认值；下面三档任一为空时回退到它。
# 单档用法：只设 LLM_MODEL，三档全用它（兼容旧配置）。
LLM_MODEL=glm-4-plus
# 三档模型（对齐 gpt-researcher 的 fast/smart/strategic）：
#   FAST_LLM_MODEL: 选角色、JSON 输出（planner/reviser/reviewer），要求快
#   SMART_LLM_MODEL: 主报告撰写（写正文/章节），质量优先
#   STRATEGIC_LLM_MODEL: 深度规划、拆子主题（生成大纲/子查询）
# 留空则回退到 LLM_MODEL。
# FAST_LLM_MODEL=glm-4-flash
# SMART_LLM_MODEL=glm-4-plus
# STRATEGIC_LLM_MODEL=glm-4-plus

# ===== Embedding（统一走 OpenAI 兼容接口，可与 LLM 不同来源）=====
# GLM / DeepSeek / OpenAI / 自建 Ollama 的 /v1/embeddings 都接同一套代码。
EMBED_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBED_MODEL=embedding-3
# API Key 留空则回退到 ZHIPU_API_KEY（Ollama 等 keyless 服务填任意非空值）。
EMBED_API_KEY=

# --- 示例：LLM 用 GLM，Embedding 用自建 Ollama（OpenAI 兼容层 /v1）---
# EMBED_BASE_URL=http://your-ollama-host:11434/v1
# EMBED_MODEL=nomic-embed-text
# EMBED_API_KEY=ollama   # Ollama 不校验 key，填任意非空值即可

# ===== 服务端 =====
# HTTP 监听地址
HTTP_ADDR=:8080
# SQLite 文件路径
DB_PATH=data/z-research.db

# ===== 研究流程参数（均有内置默认值）=====
MAX_ITERATIONS=3
MAX_RESULTS=5
MAX_SCRAPE=3
SIMILARITY_THRESHOLD=0.42
COMPRESSION_THRESHOLD=8000
TOTAL_WORDS=1200
# smart 档（写报告）的 max_tokens 上限。思考模型不设会被截断（思考吃掉配额）。
SMART_TOKEN_LIMIT=8192
LANGUAGE=zh
TEMPERATURE=0.35
CONCURRENCY=3

# 全局并发上限（面试话术关键词）
# MAX_SCRAPER_WORKERS: 网页抓取的统一并发上限（所有引擎共用 workerpool）
# MAX_EMBED_WORKERS: embedding 计算的并发上限（compress 包内部）
MAX_SCRAPER_WORKERS=15
MAX_EMBED_WORKERS=4

# 深度递归模式（mode=deep）参数
# DEEP_BREADTH: 递归起始扇出数，每层按 max(2, breadth//2) 衰减
# DEEP_DEPTH: 递归层数（0=退化为叶子研究）。成本随 breadth^depth 增长。
DEEP_BREADTH=4
DEEP_DEPTH=2

# 详细报告（report_type=detailed）参数
MAX_SECTIONS=4
WORDS_PER_SECTION=800

# 多智能体：第三个循环（fact_checker + visualizer）
# 开启后 writer 之后插入 fact_checker（只看正文不看引用），
# 不通过回 writer 重写，通过则经 visualizer/publisher 输出。
ENABLE_FACT_CHECK=false
ENABLE_VISUALIZE=false
MAX_FACT_CHECK_REVISIONS=2

# 引擎模式默认值（前端可 per-request 覆盖）：single / multi / react / deep
ENGINE_MODE=single

# 多智能体 HITL（人工审核大纲）
ENABLE_HITL=false
MAX_PLAN_REVISIONS=3
MAX_DRAFT_REVISIONS=3

# 抓取策略：auto（默认，先 Jina Reader 后 goquery）/ jina / direct
# Jina Reader 是外部免费服务，偶发宕机/被墙时每个 URL 会等待超时拖死研究流程。
# 此时改 direct 可绕过 Jina（但对 JS 渲染/反爬站无效，成功率下降）。
SCRAPER_STRATEGY=auto

# Eino graph 超步上限（Pregel 引擎兜底）
MAX_RUN_STEPS=80

# ===== 超时（秒）=====
# glm-5.1 等思考模型写长报告可能要数分钟，默认 600s（10 分钟）。
# 用快速模型（如 glm-4-plus）时可调小到 120。
LLM_TIMEOUT_SECONDS=600
EMBED_TIMEOUT_SECONDS=60
