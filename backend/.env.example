# ===== 必填：LLM 凭证 =====
# 智谱 GLM API Key (https://open.bigmodel.cn/)  —— 请填入你自己的密钥
ZHIPU_API_KEY=

# ===== LLM（OpenAI 兼容）=====
# 留空则使用默认 GLM 端点。可改为 DeepSeek / OpenAI / 代理等 OpenAI 兼容服务。
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-plus

# ===== Embedding（统一走 OpenAI 兼容接口，可与 LLM 不同来源）=====
# GLM / DeepSeek / OpenAI / 自建 Ollama 的 /v1/embeddings 都接同一套代码。
EMBED_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBED_MODEL=embedding-3
# API Key 留空则回退到 ZHIPU_API_KEY（Ollama 等 keyless 服务填任意非空值）。
EMBED_API_KEY=

# --- 示例：LLM 用 GLM，Embedding 用自建 Ollama（OpenAI 兼容层 /v1）---
# EMBED_BASE_URL=http://your-ollama-host:11434/v1
# EMBED_MODEL=nomic-embed-text
# EMBED_API_KEY=ollama   # Ollama 不校验 key，填任意非空值即可

# ===== 服务端 =====
# HTTP 监听地址
HTTP_ADDR=:8080
# SQLite 文件路径
DB_PATH=data/z-research.db

# ===== 研究流程参数（均有内置默认值）=====
MAX_ITERATIONS=3
MAX_RESULTS=5
MAX_SCRAPE=3
SIMILARITY_THRESHOLD=0.42
COMPRESSION_THRESHOLD=8000
TOTAL_WORDS=1200
LANGUAGE=zh
TEMPERATURE=0.35
CONCURRENCY=3

# ===== 超时（秒）=====
# glm-5.1 等思考模型写长报告可能要数分钟，默认 600s（10 分钟）。
# 用快速模型（如 glm-4-plus）时可调小到 120。
LLM_TIMEOUT_SECONDS=600
EMBED_TIMEOUT_SECONDS=60
